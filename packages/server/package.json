{
  "name": "@marinara-engine/server",
  "version": "1.3.3",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch --ignore ./data src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "clean": "rm -rf dist *.tsbuildinfo",
    "lint": "tsc --noEmit",
    "db:generate": "drizzle-kit generate --config=drizzle.config.cts",
    "db:push": "drizzle-kit push --config=drizzle.config.cts",
    "db:migrate": "drizzle-kit migrate --config=drizzle.config.cts",
    "db:studio": "drizzle-kit studio --config=drizzle.config.cts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/multipart": "^9.0.0",
    "@fastify/static": "^8.1.0",
    "@fastify/websocket": "^11.0.0",
    "@libsql/client": "^0.15.0",
    "@marinara-engine/shared": "workspace:*",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.38.0",
    "fastify": "^5.2.0",
    "nanoid": "^5.1.0",
    "pdf-parse": "^2.4.5",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "png-chunk-text": "^1.0.0",
    "png-chunks-extract": "^1.0.0",
    "zod": "^3.24.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pdf-parse": "^1.1.5",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
