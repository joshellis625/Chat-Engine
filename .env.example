# Marinara Engine Environment Configuration
# Copy this file to .env and fill in the values

# Server
PORT=7860
# Bare `pnpm start` defaults to 127.0.0.1; the shell launchers default to 0.0.0.0 unless you override HOST here.
HOST=0.0.0.0
# Shell launchers open the local URL by default. Set false to disable.
AUTO_OPEN_BROWSER=true

# Database
# Relative file paths resolve from packages/server for compatibility with existing local installs.
DATABASE_URL=file:./data/marinara-engine.db
# If data appears missing after a recent update, check both packages/server/data/ and data/.
# Do not delete either folder until you confirm which database your install is using.

# Encryption key for API keys at rest (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=
# Optional secret for destructive admin endpoints such as /api/admin/clear-all
# ADMIN_SECRET=

# Logging
LOG_LEVEL=info

# CORS (comma-separated origins, or * for allow-all without credentials)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# SSL/TLS — set both to enable HTTPS (leave empty for plain HTTP)
# SSL_CERT=/path/to/fullchain.pem
# SSL_KEY=/path/to/privkey.pem

# IP Allowlist — comma-separated IPs or CIDRs (e.g. 192.168.1.100,10.0.0.0/24)
# When set, all other IPs are blocked. Loopback (127.0.0.1/::1) is always allowed.
# IP_ALLOWLIST=

# Giphy GIF API — get a free key from https://developers.giphy.com/
# (optional; GIF search is disabled when unset)
# GIPHY_API_KEY=
